PORT=3001
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
BACKUP_ENABLED=false
HORIZON_URL=https://horizon-testnet.stellar.org
CONTRACT_ID=CA... # Replace with actual deployed contract ID
DATABASE_URL=postgresql://user:pass@localhost:5432/stellar_save
INDEXER_ENABLED=true

# ========== JWT AUTH ==========
JWT_SECRET=replace-with-a-long-random-secret-in-production
JWT_EXPIRES_IN=24h

# ========== NOTIFICATION SERVICE (Issue #557) ==========
SENDGRID_API_KEY=SG... # Your SendGrid API key
SENDGRID_FROM_EMAIL=noreply@stellar-save.com
SENDGRID_REPLY_TO=support@stellar-save.com

# Firebase Cloud Messaging (FCM)
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_SERVICE_ACCOUNT={"type":"service_account",...} # Firebase service account JSON (minified)

# OneSignal (Alternative to Firebase)
ONESIGNAL_APP_ID=your-onesignal-app-id
ONESIGNAL_API_KEY=your-onesignal-api-key

# Push notification provider selection
PUSH_PROVIDER=firebase # Options: firebase, onesignal

# Frontend URL for unsubscribe links and redirects
FRONTEND_URL=https://stellar-save.com
APP_URL=https://stellar-save.com

# Notification processing
NOTIFICATION_QUEUE_BATCH_SIZE=100
NOTIFICATION_QUEUE_INTERVAL=60000 # Run every 60 seconds

# Email digest configuration
DIGEST_EMAIL_ENABLED=true
DIGEST_EMAIL_SCHEDULE=0 9 * * * # Daily at 9 AM (cron format)