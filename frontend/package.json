{
  "name": "stellar-save-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage --run",
    "test:coverage:watch": "vitest --coverage",
    "lhci": "lhci autorun --config .lighthouserc.json --upload.target temporary-public-storage",
    "test:e2e": "vitest run src/test/integration",
    "test:e2e:testnet": "tsx src/test/e2e-testnet/testnet.e2e.ts",
    "test:mutation": "stryker run stryker.config.mjs",
    "test:mutation:ci": "stryker run stryker.config.mjs --reporters json,clear-text --concurrency 2",
    "test:a11y": "vitest run src/test/a11y.test.tsx",
    "test:a11y:pa11y": "pa11y-ci --config .pa11yrc.json",
    "test:a11y:ci": "vitest run src/test/a11y.test.tsx --reporter=verbose",
    "test:visual": "percy exec -- playwright test --config=playwright.visual.config.ts",
    "test:visual:ci": "percy exec -- playwright test --config=playwright.visual.config.ts --reporter=github"
  },
  "dependencies": {
    "@creit.tech/stellar-wallets-kit": "2.2.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^7.3.9",
    "@mui/material": "^7.3.9",
    "@mui/x-data-grid": "^7.28.3",
    "@mui/icons-material": "^7.3.9",
    "@stellar/freighter-api": "^6.0.1",
    "@stellar/stellar-sdk": "^14.5.0",
    "@tanstack/react-query": "^5.100.14",
    "i18next": "24.2.3",
    "react": "^19.2.0",
    "react-big-calendar": "^1.19.4",
    "react-dom": "^19.2.0",
    "react-i18next": "15.5.1",
    "react-router-dom": "^7.13.2",
    "recharts": "^3.8.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@axe-core/react": "^4.11.1",
    "@eslint/js": "^9.39.1",
    "@percy/cli": "^1.31.10",
    "@percy/playwright": "^1.1.0",
    "@playwright/test": "^1.58.2",
    "@sentry/react": "^10.50.0",
    "@sentry/tracing": "^7.120.4",
    "@stryker-mutator/core": "^8.7.1",
    "@stryker-mutator/vitest-runner": "^8.7.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-big-calendar": "^1.16.3",
    "@types/react-dom": "^19.2.3",
    "@types/recharts": "^1.8.29",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/coverage-v8": "^2.1.9",
    "@vitest/ui": "^2.1.8",
    "dotenv": "^17.3.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "fast-check": "^4.6.0",
    "globals": "^16.5.0",
    "jest-axe": "^10.0.0",
    "jsdom": "^25.0.1",
    "lighthouse-ci": "^1.13.1",
    "lz-string": "^1.5.0",
    "pa11y-ci": "^3.1.0",
    "pretty-format": "^29.7.0",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "vitest": "^2.1.8",
    "vitest-axe": "^0.1.0"
  }
}
