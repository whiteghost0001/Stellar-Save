# Testnet E2E Configuration
# Copy this file to .env.testnet and fill in the values.
# NEVER commit .env.testnet — it contains private keys.

# ── Stellar Testnet RPC ───────────────────────────────────────────────────────
TESTNET_RPC_URL=https://soroban-testnet.stellar.org

# ── Deployed contract address ─────────────────────────────────────────────────
# Deploy with: ./scripts/deploy_testnet.sh
# Then paste the contract ID here.
STELLAR_SAVE_CONTRACT_ID=<your-deployed-contract-id>

# ── Test wallets (Stellar testnet keypairs) ───────────────────────────────────
# Generate with: node -e "const {Keypair}=require('@stellar/stellar-sdk'); const k=Keypair.random(); console.log('Public:',k.publicKey(),'\nSecret:',k.secret())"
# Fund with Friendbot (done automatically by the test runner, or manually):
#   curl "https://friendbot.stellar.org?addr=<PUBLIC_KEY>"
#
# Wallet A — acts as group creator
TEST_WALLET_A_SECRET=<secret-key-for-wallet-a>
# TEST_WALLET_A_PUBLIC=<public-key-for-wallet-a>   # for reference only

# Wallet B — acts as a second member
TEST_WALLET_B_SECRET=<secret-key-for-wallet-b>
# TEST_WALLET_B_PUBLIC=<public-key-for-wallet-b>   # for reference only
